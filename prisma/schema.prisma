datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Activity {
  id                String       @id @default(uuid())
  clerkUserId       String
  title             String
  description       String?
  idealTime         String       // "HH:MM"
  flexibilityWindow Int          // minutes
  icon              String
  color             String
  reminderEnabled   Boolean      @default(true)
  archived          Boolean      @default(false)
  order             Int
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  entries           DailyEntry[]

  @@index([clerkUserId])
}

model DailyEntry {
  id             String   @id @default(uuid())
  clerkUserId    String
  activityId     String
  activity       Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  date           String   // "YYYY-MM-DD"
  idealTime      String   // "HH:MM"
  actualTime     String?  // "HH:MM"
  status         String   // "pending" | "on-time" | "late" | "early" | "skipped"
  deviation      Int      // minutes
  alignmentScore Int      // score 0-100
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([date, activityId])
  @@index([clerkUserId])
}

model UserSettings {
  clerkUserId          String   @id
  theme                String   @default("dark")
  defaultFlexibility   Int      @default(15)
  dailyReminder        Boolean  @default(true)
  weeklyReport         Boolean  @default(true)
  streakAlerts         Boolean  @default(true)
  insightNotifications Boolean  @default(true)
  reminderTime         String   @default("08:00")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
